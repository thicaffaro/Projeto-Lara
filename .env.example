# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=          # Apenas para seed inicial. Trocar após primeiro login.
TOKEN_ENCRYPTION_KEY=

# ── Meta — WhatsApp Business Cloud API ────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_CONFIG_ID=
META_GRAPH_VERSION=v19.0
META_MEDIA_DOWNLOAD_TIMEOUT_MS=10000
# Versões públicas (browser) — APP_ID e CONFIG_ID não são segredos (equiv. a OAuth client_id)
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=
NEXT_PUBLIC_META_GRAPH_VERSION=v19.0

# ── Lara Official Phone ────────────────────────────────────────────────────────
# Remetente de mensagens para esteticistas (Canal 1 — ver /docs/communication-channels.md)
LARA_OFFICIAL_PHONE=+5511978663056
LARA_OFFICIAL_WABA_ID=
LARA_OFFICIAL_PHONE_ID=
LARA_OFFICIAL_ACCESS_TOKEN=

# Destinatário de alertas operacionais internos (Canal 2 — ver /docs/communication-channels.md)
# MVP: mesmo número do oficial. Em produção: separar para número/grupo interno da equipe ops.
LARA_OPS_PHONE=+5511978663056

# ── Twilio (SMS de recuperação de acesso) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Meta — Instagram (stub, ativo pós-MVP) ────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ── xAI Grok (LLM principal) ──────────────────────────────────────────────────
XAI_API_KEY=
XAI_MODEL=grok-3-mini
XAI_BASE_URL=https://api.x.ai/v1

# ── Anthropic (fallback se Grok indisponível) ─────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001

# ── Mercado Pago ───────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# ── n8n (automações no Railway) ───────────────────────────────────────────────
N8N_BASE_URL=
N8N_API_KEY=
N8N_ENCRYPTION_KEY=
N8N_WEBHOOK_SECRET=     # Segredo compartilhado para validar chamadas n8n → Next.js

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Geocoding ─────────────────────────────────────────────────────────────────
NOMINATIM_USER_AGENT=lara-assistente
GOOGLE_PLACES_API_KEY=

# ── Aplicação ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://laraassistente.com.br
NEXTAUTH_SECRET=
NODE_ENV=development
